{
  "$schema": "design-tokens-v2",
  "version": "2.0.0",
  "name": "FREQUENCY Design Tokens",
  "date": "2026-04-22",
  "description": "FREQUENCY v1.0 컨셉 기반 디자인 토큰. Signal Green + Orange 역할 분리, Dark + Light 양쪽 지원.",

  "color": {
    "__doc": "의미(semantic)로 정의하고, 모드별 값은 theme.dark / theme.light 에서 참조. 포인트 컬러는 계기판 LED처럼 작동.",

    "brand": {
      "signal-green": {
        "50":  "#E8FFF2",
        "100": "#C9FFE0",
        "200": "#8CFFC0",
        "300": "#4DFF9E",
        "400": "#26FA85",
        "500": "#00E066",
        "600": "#00B853",
        "700": "#008C3E",
        "800": "#006630",
        "900": "#003E1C",
        "__role": "On Air / READY / 수신 / 성공. 살아있는 LED 느낌. 주 액티브 신호."
      },
      "te-orange": {
        "50":  "#FFF2EB",
        "100": "#FFDDC9",
        "200": "#FFB68F",
        "300": "#FF8F55",
        "400": "#FF6F28",
        "500": "#F15A24",
        "600": "#C9430F",
        "700": "#9E3308",
        "800": "#752506",
        "900": "#4A1603",
        "__role": "Transmit 액션 / RECHARGING / 경고. Teenage Engineering 시그니처 오렌지."
      },
      "amber": {
        "500": "#F5A623",
        "__role": "Sub-accent. 리차지 진행 게이지, 주의 레벨."
      },
      "critical-red": {
        "500": "#E5484D",
        "__role": "에러, 삭제, Sign Off 등 취소할 수 없는 부정 액션."
      }
    },

    "neutral": {
      "__doc": "무광 금속 패널 계열. 다크/라이트 모두 이 스케일에서 뽑아 씀.",
      "ink-1000": "#0A0A0A",
      "ink-950":  "#111111",
      "ink-900":  "#1A1A1A",
      "ink-800":  "#242424",
      "ink-700":  "#2E2E2E",
      "ink-600":  "#3D3D3D",
      "ink-500":  "#5A5A5A",
      "ink-400":  "#7A7A7A",
      "ink-300":  "#A0A0A0",
      "ink-200":  "#C8C8C8",
      "ink-150":  "#D8D8D8",
      "ink-100":  "#E8E8E8",
      "ink-50":   "#F4F4F4",
      "ink-0":    "#FFFFFF"
    },

    "theme": {
      "dark": {
        "bg": {
          "canvas":    "{neutral.ink-900}",
          "surface-1": "{neutral.ink-800}",
          "surface-2": "{neutral.ink-700}",
          "surface-3": "{neutral.ink-600}",
          "overlay":   "rgba(0, 0, 0, 0.6)",
          "__doc":     "canvas = 기기 바디, surface-1/2 = 모듈/카드, surface-3 = 눌린 버튼"
        },
        "text": {
          "primary":   "{neutral.ink-50}",
          "secondary": "{neutral.ink-200}",
          "tertiary":  "{neutral.ink-400}",
          "inverse":   "{neutral.ink-900}",
          "mono":      "{neutral.ink-100}",
          "__doc":     "mono = 모노스페이스 상태 라벨 전용 (READY/RECHARGING 등)"
        },
        "border": {
          "subtle":   "{neutral.ink-700}",
          "default":  "{neutral.ink-600}",
          "strong":   "{neutral.ink-500}",
          "focus":    "{brand.signal-green.400}"
        },
        "led": {
          "on-air":      "{brand.signal-green.400}",
          "on-air-glow": "rgba(38, 250, 133, 0.35)",
          "ready":       "{brand.signal-green.500}",
          "recharging":  "{brand.te-orange.500}",
          "warning":     "{brand.amber.500}",
          "error":       "{brand.critical-red.500}",
          "standby":     "{neutral.ink-500}",
          "silent":      "{neutral.ink-600}",
          "__doc":       "모든 LED는 1-2px 원형 + 은은한 glow. standby/silent 는 꺼진 LED."
        },
        "action": {
          "primary-bg":     "{brand.signal-green.500}",
          "primary-fg":     "{neutral.ink-1000}",
          "transmit-bg":    "{brand.te-orange.500}",
          "transmit-fg":    "{neutral.ink-0}",
          "danger-bg":      "{brand.critical-red.500}",
          "danger-fg":      "{neutral.ink-0}",
          "ghost-bg":       "transparent",
          "ghost-fg":       "{neutral.ink-50}",
          "ghost-border":   "{neutral.ink-600}"
        }
      },
      "light": {
        "bg": {
          "canvas":    "{neutral.ink-50}",
          "surface-1": "{neutral.ink-0}",
          "surface-2": "{neutral.ink-100}",
          "surface-3": "{neutral.ink-150}",
          "overlay":   "rgba(26, 26, 26, 0.45)",
          "__doc":     "라이트 모드는 은은한 흰 매트 알루미늄 느낌. 너무 밝지 않게."
        },
        "text": {
          "primary":   "{neutral.ink-950}",
          "secondary": "{neutral.ink-700}",
          "tertiary":  "{neutral.ink-500}",
          "inverse":   "{neutral.ink-0}",
          "mono":      "{neutral.ink-900}"
        },
        "border": {
          "subtle":   "{neutral.ink-100}",
          "default":  "{neutral.ink-150}",
          "strong":   "{neutral.ink-300}",
          "focus":    "{brand.signal-green.600}"
        },
        "led": {
          "on-air":      "{brand.signal-green.500}",
          "on-air-glow": "rgba(0, 224, 102, 0.28)",
          "ready":       "{brand.signal-green.600}",
          "recharging":  "{brand.te-orange.500}",
          "warning":     "{brand.amber.500}",
          "error":       "{brand.critical-red.500}",
          "standby":     "{neutral.ink-300}",
          "silent":      "{neutral.ink-200}",
          "__doc":       "라이트 모드에서도 LED는 같은 hue. 주변 대비로 '켜짐'을 전달."
        },
        "action": {
          "primary-bg":     "{brand.signal-green.500}",
          "primary-fg":     "{neutral.ink-1000}",
          "transmit-bg":    "{brand.te-orange.500}",
          "transmit-fg":    "{neutral.ink-0}",
          "danger-bg":      "{brand.critical-red.500}",
          "danger-fg":      "{neutral.ink-0}",
          "ghost-bg":       "transparent",
          "ghost-fg":       "{neutral.ink-900}",
          "ghost-border":   "{neutral.ink-200}"
        }
      }
    }
  },

  "typography": {
    "__doc": "시스템/상태 = 모노스페이스 대문자 (계기판), 본문 = 산세리프 (한글+영문).",
    "font-family": {
      "mono":    "'JetBrains Mono', 'IBM Plex Mono', ui-monospace, 'SF Mono', monospace",
      "sans":    "'Pretendard Variable', 'Pretendard', 'Inter', -apple-system, BlinkMacSystemFont, 'Apple SD Gothic Neo', sans-serif",
      "display": "'Pretendard Variable', 'Pretendard', 'Inter', sans-serif",
      "__doc":   "Pretendard = 한글 우선, 영문 fallback. JetBrains Mono = 모노 1순위. 추후 Berkeley Mono 등 유료 대체 검토 가능."
    },
    "font-weight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "font-size": {
      "10": "10px",
      "11": "11px",
      "12": "12px",
      "13": "13px",
      "14": "14px",
      "15": "15px",
      "16": "16px",
      "18": "18px",
      "20": "20px",
      "24": "24px",
      "28": "28px",
      "32": "32px",
      "40": "40px",
      "48": "48px",
      "64": "64px"
    },
    "line-height": {
      "tight":   1.1,
      "snug":    1.25,
      "normal":  1.4,
      "relaxed": 1.55
    },
    "letter-spacing": {
      "mono-caps":  "0.08em",
      "mono-label": "0.04em",
      "tight":      "-0.02em",
      "normal":     "0",
      "wide":       "0.02em"
    },
    "role": {
      "__doc": "실사용 시 이 role 기반으로 CSS 변수 노출.",
      "status-label":   { "family": "mono",  "size": "11",  "weight": "bold",     "tracking": "mono-caps",  "case": "upper" },
      "status-value":   { "family": "mono",  "size": "13",  "weight": "semibold", "tracking": "mono-label", "case": "upper" },
      "frequency":      { "family": "mono",  "size": "40",  "weight": "medium",   "tracking": "mono-label", "case": "upper" },
      "callsign":       { "family": "mono",  "size": "16",  "weight": "semibold", "tracking": "mono-label", "case": "upper" },
      "body":           { "family": "sans",  "size": "14",  "weight": "regular",  "tracking": "normal",     "line": "normal"  },
      "body-small":     { "family": "sans",  "size": "12",  "weight": "regular",  "tracking": "normal",     "line": "normal"  },
      "heading-1":      { "family": "display", "size": "24", "weight": "semibold", "tracking": "tight",    "line": "snug"   },
      "heading-2":      { "family": "display", "size": "18", "weight": "semibold", "tracking": "tight",    "line": "snug"   },
      "caption":        { "family": "mono",  "size": "10",  "weight": "medium",   "tracking": "mono-caps",  "case": "upper" }
    }
  },

  "spacing": {
    "__doc": "4px 베이스. 모든 레이아웃 이 스케일만 사용.",
    "0":  "0",
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px"
  },

  "radius": {
    "__doc": "기기 정밀함 유지. 둥근 귀여움 금지. LED dot 만 원형.",
    "none":  "0",
    "xs":    "2px",
    "sm":    "4px",
    "md":    "6px",
    "lg":    "10px",
    "xl":    "14px",
    "pill":  "999px",
    "frame": "44px"
  },

  "border-width": {
    "hairline": "1px",
    "default":  "1.5px",
    "strong":   "2px"
  },

  "shadow": {
    "__doc": "다크는 shadow 거의 없음 (border 로 분리). 라이트는 매우 약한 그림자.",
    "dark": {
      "none": "none",
      "1":    "0 0 0 1px rgba(255, 255, 255, 0.06)",
      "2":    "0 8px 24px -12px rgba(0, 0, 0, 0.5)",
      "led-green":  "0 0 12px rgba(38, 250, 133, 0.45)",
      "led-orange": "0 0 12px rgba(241, 90, 36, 0.45)"
    },
    "light": {
      "none": "none",
      "1":    "0 1px 2px rgba(26, 26, 26, 0.06)",
      "2":    "0 8px 20px -10px rgba(26, 26, 26, 0.15)",
      "led-green":  "0 0 10px rgba(0, 224, 102, 0.35)",
      "led-orange": "0 0 10px rgba(241, 90, 36, 0.35)"
    }
  },

  "motion": {
    "__doc": "컨셉 v1.0 섹션 7.7 준수. 모든 모션 0.15-0.4s. 기계적 정확함.",
    "duration": {
      "instant":  "0ms",
      "tick":     "80ms",
      "fast":     "150ms",
      "base":     "200ms",
      "medium":   "250ms",
      "slow":     "300ms",
      "slower":   "400ms"
    },
    "easing": {
      "linear":       "linear",
      "mechanical":   "cubic-bezier(0.2, 0, 0, 1)",
      "detent":       "cubic-bezier(0.4, 0, 0.2, 1)",
      "bounce-soft":  "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "__doc":        "mechanical = 셔터/전송. detent = 다이얼 스텝. bounce-soft = 완충 완료 LED 점등."
    },
    "interactions": {
      "dial-step":         { "duration": "tick",   "easing": "detent" },
      "shutter-press":     { "duration": "fast",   "easing": "mechanical" },
      "film-winding":      { "duration": "slow",   "easing": "mechanical" },
      "transmit-launch":   { "duration": "medium", "easing": "mechanical" },
      "channel-switch":    { "duration": "slow",   "easing": "mechanical" },
      "led-toggle":        { "duration": "base",   "easing": "bounce-soft" }
    }
  },

  "haptic": {
    "__doc": "iOS UIImpactFeedbackGenerator / UINotificationFeedbackGenerator 매핑.",
    "dial-step":         "light",
    "frequency-match":   "medium",
    "shutter":           "rigid",
    "transmit-complete": "success",
    "signal-back":       "soft",
    "mismatch-error":    "error"
  },

  "size": {
    "touch-target-min": "44px",
    "icon-xs":   "14px",
    "icon-sm":   "16px",
    "icon-md":   "20px",
    "icon-lg":   "24px",
    "icon-xl":   "32px",
    "led-dot":   "6px",
    "led-dot-lg":"8px",
    "ptt-button":"72px",
    "frequency-dial-diameter": "240px",
    "__doc": "iOS HIG 최소 터치 영역 44px 준수."
  },

  "z-index": {
    "base":     0,
    "elevated": 10,
    "sticky":   100,
    "overlay":  1000,
    "modal":    2000,
    "toast":    3000
  }
}
